@@ -105,6 +110,43 @@ void ModeThrow::run()
         pos_control->relax_z_controller(0.0f);
         break;
 
+    // ── NEW STAGE ──────────────────────────────────────────────────────────
+    // Throw_Servo: actuate servo on throw detection; hold motors off until
+    // the configured delay expires, then advance to Throw_Uprighting.
+    // ──────────────────────────────────────────────────────────────────────
+    case Throw_Servo: {
+        if (!throw_srv_activated) {
+            // Pulse the configured servo channel to the configured PWM value.
+            // The channel must have SERVOx_FUNCTION = k_throw_srv (213).
+            if (g.throw_srv_ch > 0) {
+                SRV_Channels::set_output_pwm(SRV_Channel::k_throw_srv,
+                                             (uint16_t)g.throw_srv_pwm);
+                gcs().send_text(MAV_SEVERITY_INFO,
+                                "Throw mode: servo pwm=%d set",
+                                (int)g.throw_srv_pwm);
+            }
+            throw_srv_start_ms  = AP_HAL::millis();
+            throw_srv_activated = true;
+        }
+
+        uint32_t elapsed_ms = AP_HAL::millis() - throw_srv_start_ms;
+        uint32_t delay_ms   = (uint32_t)MAX(0, (int32_t)g.throw_srv_dly_ms);
+
+        if (elapsed_ms >= delay_ms) {
+            // Delay elapsed → proceed to uprighting
+            stage = Throw_Uprighting;
+            gcs().send_text(MAV_SEVERITY_INFO,
+                            "Throw mode: servo delay elapsed (%u ms), uprighting",
+                            (unsigned)elapsed_ms);
+        }
+
+        // Motors remain stopped throughout the servo delay window
+        attitude_control->reset_yaw_target_and_rate();
+        attitude_control->reset_rate_controller_I_terms();
+        attitude_control->set_throttle_out(0.0f, true, g.throttle_filt);
+        pos_control->relax_z_controller(0.0f);
+        break;
+    }
+    // ── END NEW STAGE ──────────────────────────────────────────────────────
+
     case Throw_Uprighting:
