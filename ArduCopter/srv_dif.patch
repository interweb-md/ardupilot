+
+            // NEW: confirmed throw → enter servo stage instead of jumping directly to uprighting
             if (throw_condition_confirmed) {
-                stage = Throw_Uprighting;
-                gcs().send_text(MAV_SEVERITY_INFO, "Throw mode: throw detected");
+                stage = Throw_Servo;
